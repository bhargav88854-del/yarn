// Yarn Inventory — Prisma schema (PostgreSQL / Supabase).
// DATABASE_URL = pooled connection (pgbouncer) used at runtime.
// DIRECT_URL   = direct connection used for migrations.

generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Yarn {
  id           Int           @id @default(autoincrement())
  yarnId       String        @unique // Y001, Y002...
  name         String
  material     String
  color        String
  quantity     Int
  unit         String        @default("Cones") // Cones, Kg, Boxes...
  costPerCone  Float         @default(0) // unit cost for stock valuation
  reorderLevel Int           @default(50) // per-yarn low-stock threshold
  location     String // Rack A-12
  supplier     String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]
}

model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  name         String
  passwordHash String
  role         String        @default("staff") // staff | admin
  createdAt    DateTime      @default(now())
  transactions Transaction[]
}

model Transaction {
  id        Int      @id @default(autoincrement())
  yarnId    Int
  type      String // IN or OUT
  quantity  Int
  note      String? // free-text reason
  reference String? // PO / invoice number
  userId    Int? // who logged it (null for legacy/seed rows)
  date      DateTime @default(now())
  yarn      Yarn     @relation(fields: [yarnId], references: [id])
  user      User?    @relation(fields: [userId], references: [id])
}
