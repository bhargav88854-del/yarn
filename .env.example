# PostgreSQL (Supabase). Get both from Supabase → Project Settings → Database.
# DATABASE_URL = "Connection pooling" string (port 6543, add ?pgbouncer=true).
# DIRECT_URL   = "Direct connection" string (port 5432) — used for migrations.
DATABASE_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxx:PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres"

# NextAuth (Auth.js) — generate with: openssl rand -base64 33
AUTH_SECRET="replace-with-a-long-random-string"

# Google Gemini (AI chatbot)
GEMINI_API_KEY="your-gemini-api-key"
# GEMINI_MODEL="gemini-2.5-flash"
