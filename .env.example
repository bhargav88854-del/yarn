# Local dev uses SQLite (zero-config). Prisma reads DATABASE_URL.
DATABASE_URL="file:./dev.db"

# For production (Supabase / PostgreSQL) switch the datasource provider in
# prisma/schema.prisma to "postgresql" and set:
# DATABASE_URL="postgresql://USER:PASS@HOST:5432/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://USER:PASS@HOST:5432/postgres"
